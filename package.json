{
    "name": "@cybearl/cypack",
    "productName": "CyPack",
    "version": "0.0.0-semantically-released",
    "description": "A set of general utilities for Cybearl projects.",
    "author": "Cybearl <contact@cybearl.com> (https://www.cybearl.com/)",
    "license": "MIT",
    "private": false,
    "packageManager": "npm@11.4.2",
    "type": "module",
    "keywords": [
        "cybearl",
        "cypack",
        "utilities"
    ],
    "homepage": "https://github.com/cybearl/cypack",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cybearl/cypack.git"
    },
    "bugs": {
        "url": "https://github.com/cybearl/cypack/issues"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public",
        "tag": "latest"
    },
    "engines": {
        "node": ">=22.20.0"
    },
    "files": [
        "*"
    ],
    "main": "./index.js",
    "module": "./index.js",
    "types": "./index.d.ts",
    "exports": {
        "./backend": {
            "types": "./backend.d.ts",
            "node": "./backend.js",
            "default": "./backend.js"
        },
        "./frontend": {
            "types": "./frontend.d.ts",
            "import": "./frontend.js",
            "default": "./frontend.js"
        },
        ".": {
            "types": "./index.d.ts",
            "import": "./index.js",
            "default": "./index.js"
        }
    },
    "scripts": {
        "knip": "knip",
        "lint": "biome check",
        "lint:fix": "biome check --fix && biome format --write",
        "test:sandbox": "tsx ./tests/sandbox.ts",
        "test:bench": "tsx ./tests/benchmark.ts",
        "test:unit": "vitest",
        "test": "npm run test:unit",
        "build": "tsup",
        "release": "npx semantic-release"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "colorette": "^2.0.20",
        "dateformat": "^5.0.3",
        "dedent-js": "^1.0.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "slugify": "^1.6.9",
        "tailwind-merge": "^3.3.1"
    },
    "peerDependencies": {
        "next": "^15.5.15",
        "react": "^19.1.1",
        "react-dom": "^19.2.5",
        "typescript": ">=5.8.3"
    },
    "peerDependenciesMeta": {
        "next": {
            "optional": true
        },
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@types/copyfiles": "^2.4.4",
        "@types/dateformat": "^5.0.3",
        "@types/minimist": "^1.2.5",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "copyfiles": "^2.4.1",
        "cz-conventional-changelog": "^3.3.0",
        "knip": "^6.7.0",
        "minimist": "^1.2.8",
        "next": "16.2.4",
        "next-auth": "^4.24.14",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "semantic-release": "^25.0.3",
        "tsup": "^8.5.1",
        "tsx": "^4.20.6",
        "typescript": "^5.8.3",
        "vite": "^8.0.10",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.5"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.60.2",
        "@rollup/rollup-win32-x64-msvc": "^4.60.2"
    },
    "resolutions": {
        "@types/react": "^19.1.1",
        "@types/react-dom": "^19.1.1"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    }
}